#!/bin/bash

threshold=10

HOST=$(hostname)
DATE=$(date +%F)

echo "Filesystem usage report on ${HOST}_${DATE}"

df -hTP | awk 'NR>1 {print $1, $7, $6}' | while read -r fs mountedon usage
do
    use=${usage%\%}

    if [[ "$use" -ge "$threshold" ]]; then

        {
            echo "======================================================="
            echo -e "\tFileSystem\t:\t$fs"
            echo -e "\tMountPoint\t:\t$mountedon"
            echo -e "\tUsage\t\t:\t$usage"
            echo -e "\tHostname\t:\t$HOST"
            echo "======================================================="

            echo "### df -hTP $mountedon #####"
            df -hTP "$mountedon"

            echo
            echo "=========== TOP 10 Directories (with Owner/Group) =========="

            du -h --max-depth=1 "$mountedon" 2>/dev/null | sort -rh | head -10 | while read -r size path
            do
                owner=$(stat -c '%U' "$path" 2>/dev/null)
                group=$(stat -c '%G' "$path" 2>/dev/null)

                printf "%-8s %-20s Owner:%-10s Group:%-10s\n" "$size" "$path" "$owner" "$group"
            done

            echo
            echo "=========== TOP 10 Files (with Owner/Group) =========="

            find "$mountedon" -type f \
                -not -path "$mountedon/proc/*" \
                -not -path "$mountedon/sys/*" \
                -not -path "$mountedon/dev/*" \
                -exec du -h {} + 2>/dev/null | sort -rh | head -10 | while read -r size file
            do
                owner=$(stat -c '%U' "$file" 2>/dev/null)
                group=$(stat -c '%G' "$file" 2>/dev/null)

                printf "%-8s %-50s Owner:%-10s Group:%-10s\n" "$size" "$file" "$owner" "$group"
            done

            echo
            echo "=========== TOP 5 Items (Quick View) =========="

            cd "$mountedon" || exit
            du -sh * 2>/dev/null | sort -rh | head -5 | while read -r size item
            do
                owner=$(stat -c '%U' "$item" 2>/dev/null)
                group=$(stat -c '%G' "$item" 2>/dev/null)

                printf "%-8s %-20s Owner:%-10s Group:%-10s\n" "$size" "$item" "$owner" "$group"
            done

            echo "======================================================="

        } | mail -s "DISK SPACE ALERT on ${HOST} (${DATE})" "yeddula.jagadeesh@cgi.com"

    fi

done

