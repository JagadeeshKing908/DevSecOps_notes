#!/bin/bash

CPU_THRESHOLD=70

COUNT=0
LIMIT=5   # 5 minutes

EMAIL="jagadeeshcloud0@gmail.com"
HOST=$(hostname)

while true
do
    # Get CPU usage
    CPU=$(top -bn1 | grep "Cpu(s)" | awk '{print 100 - $8}')
    CPU=${CPU%.*} 

    if [[ "$CPU" -ge "$CPU_THRESHOLD" ]]; then
        ((COUNT++))
        echo "High cpu usage detected ($COUNT/$LIMIT)"
		echo "CPU: $CPU%"
		sleep 60
    else
        COUNT=0
    fi

    # If 5 continuous checks (5 mins)
    if [[ "$COUNT" -eq "$LIMIT" ]]; then

        {
            echo "ALERT: CPU usage is above ${CPU_THRESHOLD}% for 5 minutes"
            echo "Hostname: $HOST"
            echo "CPU Usage: $CPU%"
            echo "Time: $(date)"
            echo

            echo "===== TOP 5 CPU CONSUMING PROCESSES ====="
            ps -eo pid,user,%cpu,%mem,cmd --sort=-%cpu | head -6

        } | mail -s "CPU ALERT above ${CPU_THRESHOLD}% for 5 minutes on $HOST" "$EMAIL"

        COUNT=0   # reset after alert
    fi

    sleep 60   # wait 1 minute

done

