#!/bin/bash

INTERFACE="ens5"
THRESHOLD=5    # MB/s (change based on your need)
COUNT=0
LIMIT=5        # 5 minutes

EMAIL="jagadeeshcloud0@gmail.com"
HOST=$(hostname)

while true
do
    # Get RX bytes
    RX1=$(cat /sys/class/net/$INTERFACE/statistics/rx_bytes)
    TX1=$(cat /sys/class/net/$INTERFACE/statistics/tx_bytes)

    sleep 60

    RX2=$(cat /sys/class/net/$INTERFACE/statistics/rx_bytes)
    TX2=$(cat /sys/class/net/$INTERFACE/statistics/tx_bytes)

    # Calculate usage in MB/s
    RX_RATE=$(( (RX2 - RX1) / 1024 / 1024 ))
    TX_RATE=$(( (TX2 - TX1) / 1024 / 1024 ))

    TOTAL=$((RX_RATE + TX_RATE))

    echo "Network Usage: ${TOTAL} MB/s"

    if [[ "$TOTAL" -ge "$THRESHOLD" ]]; then
        ((COUNT++))
        echo "High network usage detected ($COUNT/$LIMIT)"
    else
        COUNT=0
    fi

    # If high usage for 5 minutes
    if [[ "$COUNT" -ge "$LIMIT" ]]; then

        {
            echo "ALERT: High Network Usage Detected"
            echo "Hostname: $HOST"
            echo "Interface: $INTERFACE"
            echo "Usage: ${TOTAL} MB/s"
            echo "Time: $(date)"
            echo

            echo "===== TOP 5 NETWORK USING PROCESSES ====="

            # Using ss to map connections
            ss -tunap | head -20

            echo
            echo "===== TOP 5 PROCESSES (CPU) ====="
            ps -eo pid,user,%cpu,%mem,cmd --sort=-%cpu | head -6

        } | mail -s "NETWORK ALERT on $HOST" "$EMAIL"

        COUNT=0
    fi

done


#!/bin/bash

THRESHOLD=5   # MB/s
LIMIT=5       # 5 minutes

EMAIL="jagadeeshcloud0@gmail.com"
HOST=$(hostname)

# Get all interfaces except loopback
INTERFACES=$(ls /sys/class/net | grep -v lo)

declare -A COUNT

while true
do
    for IFACE in $INTERFACES
    do
        RX1=$(cat /sys/class/net/$IFACE/statistics/rx_bytes)
        TX1=$(cat /sys/class/net/$IFACE/statistics/tx_bytes)

        sleep 60

        RX2=$(cat /sys/class/net/$IFACE/statistics/rx_bytes)
        TX2=$(cat /sys/class/net/$IFACE/statistics/tx_bytes)

        RX_RATE=$(( (RX2 - RX1) / 1024 / 1024 ))
        TX_RATE=$(( (TX2 - TX1) / 1024 / 1024 ))

        TOTAL=$((RX_RATE + TX_RATE))

        echo "[$IFACE] Usage: ${TOTAL} MB/s"

        if [[ "$TOTAL" -ge "$THRESHOLD" ]]; then
            COUNT[$IFACE]=$(( ${COUNT[$IFACE]:-0} + 1 ))
            echo "High usage on $IFACE (${COUNT[$IFACE]}/$LIMIT)"
        else
            COUNT[$IFACE]=0
        fi

        if [[ "${COUNT[$IFACE]}" -ge "$LIMIT" ]]; then

            {
                echo "ALERT: High Network Usage Detected"
                echo "Hostname: $HOST"
                echo "Interface: $IFACE"
                echo "Usage: ${TOTAL} MB/s"
                echo "Time: $(date)"
                echo

                echo "===== TOP NETWORK CONNECTIONS ====="
                ss -tunap | head -20

                echo
                echo "===== TOP 5 CPU PROCESSES ====="
                ps -eo pid,user,%cpu,%mem,cmd --sort=-%cpu | head -6

            } | mail -s "NETWORK ALERT on $HOST ($IFACE)" "$EMAIL"

            COUNT[$IFACE]=0
        fi

    done
done


